// AI Vulnerability Mining — Agent 注册与配置
// 漏洞挖掘工具链的 Agent 协作配置
{
  "version": "1.0",
  "project": "vuln-mining-tensorflow",
  "description": "AI 驱动的漏洞挖掘工具链 — C++ 源码安全审计",

  // 技能注册
  "skills": {
    "vuln-mining": {
      "path": ".agents/skills/vuln-mining/SKILL.md",
      "description": "漏洞挖掘核心技能 — SAST + LLM 融合扫描",
      "triggers": ["vuln", "vulnerability", "漏洞", "扫描"],
      "priority": "high"
    },
    "security-scanner": {
      "path": ".agents/skills/security-scanner/SKILL.md",
      "description": "安全扫描器 — 静态模式匹配",
      "triggers": ["scan", "sast", "扫描"],
      "dependencies": ["vuln-mining"]
    },
    "evidence-verifier": {
      "path": ".agents/skills/evidence-verifier/SKILL.md",
      "description": "证据验证器 — 反幻觉检查 + 证据链验证",
      "triggers": ["verify", "evidence", "验证"],
      "dependencies": ["vuln-mining"]
    },
    "anti-hallucination": {
      "path": ".agents/skills/anti-hallucination/SKILL.md",
      "description": "翻译/分析过程中的证据核验和幻觉防御",
      "triggers": ["anti-hallucination", "幻觉", "证据核验"],
      "auto_load": true
    },
    "status-dashboard": {
      "path": ".agents/skills/status-dashboard/SKILL.md",
      "description": "扫描进度仪表盘",
      "triggers": ["status", "progress", "进度"]
    },
    "shared": {
      "path": ".agents/skills/shared/SKILL.md",
      "description": "共享方法论",
      "auto_load": true
    }
  },

  // Agent 角色配置
  "agents": {
    "scanner-agent": {
      "role": "primary",
      "description": "主扫描 Agent — 负责执行漏洞挖掘工作",
      "skills": ["vuln-mining", "security-scanner", "anti-hallucination"],
      "instructions": [
        "每次会话开始先读取 reports/ 和 plans/ 恢复扫描状态",
        "严格遵循黑盒标准，不向 LLM 透露项目版本或已知漏洞",
        "按 Wave 模式扫描（3-5 模块/批）",
        "每个候选漏洞必须通过反幻觉检查",
        "所有 LLM 交互必须记录到 llm_chat_log.json"
      ]
    },
    "verifier-agent": {
      "role": "secondary",
      "description": "验证 Agent — 负责证据链验证和 PoC 生成",
      "skills": ["evidence-verifier", "anti-hallucination"],
      "instructions": [
        "每个漏洞必须有源码路径、行号、触发路径",
        "验证 LLM 声称的代码确实存在于源码中",
        "确保 PoC 可以触发漏洞",
        "生成反幻觉检查报告"
      ]
    },
    "report-agent": {
      "role": "background",
      "description": "报告 Agent — 负责交付件生成和格式合规",
      "skills": ["status-dashboard"],
      "instructions": [
        "确保 vulnerability_list.md 格式合规",
        "确保 llm_chat_log.json 完整且符合黑盒标准",
        "确保 vulnerability_report.md 包含详细分析",
        "运行 final_verify.sh 验证所有交付件"
      ]
    }
  },

  // 工作流配置
  "workflows": {
    "full-scan": {
      "description": "完整漏洞扫描流程",
      "steps": [
        { "agent": "scanner-agent", "action": "analyze", "skill": "vuln-mining" },
        { "agent": "scanner-agent", "action": "sast-scan", "skill": "security-scanner" },
        { "agent": "scanner-agent", "action": "llm-scan-wave", "skill": "vuln-mining", "repeat": true },
        { "agent": "verifier-agent", "action": "verify", "skill": "evidence-verifier" },
        { "agent": "report-agent", "action": "generate", "skill": "status-dashboard" }
      ]
    },
    "verify-only": {
      "description": "仅验证（用于修复后重新验证）",
      "steps": [
        { "agent": "verifier-agent", "action": "verify", "skill": "evidence-verifier" },
        { "agent": "report-agent", "action": "generate", "skill": "status-dashboard" }
      ]
    }
  },

  // 全局规则
  "rules": {
    "black_box_standard": true,
    "no_version_hints": true,
    "no_cve_references": true,
    "evidence_required": true,
    "ai_generated_poc": true,
    "max_wave_modules": 5,
    "min_wave_modules": 3,
    "anti_hallucination_checklist": 6,
    "min_chat_turns": 5
  }
}
